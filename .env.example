# Email delivery (Gmail recommended — use an App Password, not your main password)
SMTP_USER=you@gmail.com
SMTP_PASS=your_gmail_app_password
REPORT_EMAIL=you@gmail.com

# Slack delivery (optional — paste incoming webhook URL)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Set to true to force competitor screenshots even on non-Monday runs
FORCE_SCREENSHOTS=false
